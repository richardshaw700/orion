<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System.Configuration.ConfigurationManager, Version=5.0.0.0, Culture=neutral, PublicKeyToken=cc7b13ffcd2ddd51">
      <section name="IDRAMonitor.Properties.Settings" type="System.Configuration.ClientSettingsSection, System.Configuration.ConfigurationManager, Version=5.0.0.0, Culture=neutral, PublicKeyToken=cc7b13ffcd2ddd51" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
    </sectionGroup>
  </configSections>
  <userSettings>
    <IDRAMonitor.Properties.Settings>
      <setting name="IsRestarting" serializeAs="String">
        <value>False</value>
      </setting>
    </IDRAMonitor.Properties.Settings>
  </userSettings>
	<appSettings>
		<add key="AzureBlobStorageName" value="myazureblobaccount"/>
		<!-- Other settings can go here -->
	</appSettings>
  <connectionStrings>
	<add name="ZoneAppStorageAccountConnection" connectionString="DefaultEndpointsProtocol=https;AccountName=REDACTED;AccountKey=REDACTED;EndpointSuffix=core.windows.net"/>
  </connectionStrings>
</configuration>